{
  "name": "sleduju-ta",
  "version": "1.0.0",
  "description": "Sledujú Ťa! — Chrome extension na blokovanie tracking pixelov v emailoch",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.page.config.ts && cp dist/gmail-scanner.js public/gmail-scanner.js && vite build",
    "build:ext": "vite build",
    "build:page": "vite build --config vite.page.config.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "privacy",
    "email",
    "tracking",
    "chrome-extension",
    "gmail"
  ],
  "author": "",
  "license": "BUSL-1.1",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@preact/preset-vite": "^2.10.5",
    "jsdom": "^29.0.2",
    "preact": "^10.29.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "gmail-js": "^1.1.16",
    "jquery": "^4.0.0",
    "lucide-preact": "^1.8.0"
  }
}
